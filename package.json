{
    "name": "day-flow-workspace",
    "version": "0.1.0",
    "private": true,
    "description": "Day Flow workspace",
    "license": "Apache-2.0",
    "author": "Nizam Chaudhary",
    "maintainers": [
        "Nizam Chaudhary"
    ],
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo run dev --filter=@day-flow/desktop --filter=@day-flow/auth-server",
        "dev:desktop": "turbo run dev --filter=@day-flow/desktop",
        "dev:auth-server": "turbo run dev --filter=@day-flow/auth-server",
        "build": "turbo run build",
        "test": "turbo run test",
        "format": "oxfmt .",
        "clean": "rimraf apps/desktop/.tanstack apps/desktop/.vite .turbo apps/*/.turbo packages/*/.turbo apps/desktop/out node_modules apps/*/node_modules packages/*/node_modules",
        "lint": "oxlint . --fix --fix-suggestions",
        "db:generate": "turbo run db:generate --filter=@day-flow/db",
        "db:studio": "turbo run db:studio --filter=@day-flow/db",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "oxfmt": "^0.45.0",
        "oxlint": "^1.60.0",
        "oxlint-tsgolint": "^0.21.1",
        "rimraf": "^6.1.3",
        "turbo": "^2.5.5",
        "typescript": "6.0.3"
    },
    "lint-staged": {
        "*": "oxfmt --no-error-on-unmatched-pattern",
        "*.{js,jsx,ts,tsx,mjs,cjs}": "npm run lint"
    },
    "packageManager": "npm@11.8.0"
}
