{
    "name": "day-flow",
    "version": "0.1",
    "private": "true",
    "description": "Manage your day",
    "license": "Apache-2.0",
    "author": "Nizam Chaudhary",
    "maintainers": [
        "Nizam Chaudhary"
    ],
    "main": ".vite/build/main.js",
    "scripts": {
        "format": "oxfmt",
        "lint": "oxlint --fix --fix-suggestions",
        "prepare": "husky"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/node": "^25.6.0",
        "@typescript/native-preview": "^7.0.0-dev.20260418.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "oxfmt": "^0.45.0",
        "oxlint": "^1.60.0",
        "oxlint-tsgolint": "^0.21.1",
        "vitest": "^4.1.4"
    },
    "peerDependencies": {
        "typescript": "^6.0.3"
    },
    "lint-staged": {
        "*": "oxfmt --no-error-on-unmatched-pattern",
        "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint"
    },
    "packageManager": "bun@1.3.12",
    "productName": "Day Flow"
}
