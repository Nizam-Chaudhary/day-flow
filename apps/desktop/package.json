{
    "name": "@day-flow/desktop",
    "version": "0.1.0",
    "private": true,
    "description": "Day Flow Electron desktop app",
    "license": "Apache-2.0",
    "main": ".vite/build/main.js",
    "scripts": {
        "dev": "electron-forge start",
        "start": "npm run dev",
        "build": "electron-forge package",
        "package": "electron-forge package",
        "make": "electron-forge make",
        "make:linux": "electron-forge make --platform=linux",
        "make:deb": "electron-forge make --targets=@electron-forge/maker-deb",
        "make:rpm": "electron-forge make --targets=@electron-forge/maker-rpm",
        "make:appimage": "electron-forge make --targets=@reforged/maker-appimage",
        "make:flatpak": "electron-forge make --targets=@electron-forge/maker-flatpak",
        "make:mac": "electron-forge make --platform=darwin",
        "make:zip": "electron-forge make --targets=@electron-forge/maker-zip",
        "make:win": "electron-forge make --platform=win32",
        "make:squirrel": "electron-forge make --targets=@electron-forge/maker-squirrel",
        "publish": "electron-forge publish",
        "publish:linux": "electron-forge publish --platform=linux",
        "publish:deb": "electron-forge publish --targets=@electron-forge/maker-deb",
        "publish:rpm": "electron-forge publish --targets=@electron-forge/maker-rpm",
        "publish:appimage": "electron-forge publish --targets=@reforged/maker-appimage",
        "publish:flatpak": "electron-forge publish --targets=@electron-forge/maker-flatpak",
        "publish:mac": "electron-forge publish --platform=darwin",
        "publish:zip": "electron-forge publish --targets=@electron-forge/maker-zip",
        "publish:win": "electron-forge publish --platform=win32",
        "publish:squirrel": "electron-forge publish --targets=@electron-forge/maker-squirrel",
        "clean": "rimraf node_modules .vite .tanstack out",
        "format": "oxfmt $(rg --files src -g '*.ts' -g '*.tsx' -g '*.d.ts') forge.config.ts vite.config.ts vite.main.config.ts vite.preload.config.ts vitest.config.ts tsconfig.app.json tsconfig.node.json package.json components.json components.json.bak",
        "lint": "oxlint . --fix --fix-suggestions",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "@base-ui/react": "^1.4.0",
        "@day-flow/auth-server": "*",
        "@day-flow/contracts": "*",
        "@day-flow/db": "*",
        "@day-flow/integrations-google": "*",
        "@fontsource-variable/figtree": "^5.2.10",
        "@fontsource-variable/inter": "^5.2.8",
        "@hugeicons/core-free-icons": "^4.1.1",
        "@hugeicons/react": "^1.1.6",
        "@libsql/client": "^0.15.15",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/react-form": "^1.29.0",
        "@tanstack/react-query": "^5.99.0",
        "@tanstack/react-query-devtools": "^5.99.0",
        "@tanstack/react-router": "1.168.22",
        "@tanstack/react-router-devtools": "1.166.13",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "dotenv": "^17.4.2",
        "drizzle-orm": "^0.45.2",
        "electron-squirrel-startup": "1.0.1",
        "embla-carousel-react": "^8.6.0",
        "input-otp": "^1.4.2",
        "keytar": "^7.9.0",
        "next-themes": "^0.4.6",
        "react": "19.2.5",
        "react-day-picker": "^9.14.0",
        "react-dom": "19.2.5",
        "react-resizable-panels": "^4.10.0",
        "shadcn": "^4.3.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.4.0",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@electron-forge/cli": "7.11.1",
        "@electron-forge/maker-deb": "7.11.1",
        "@electron-forge/maker-flatpak": "^7.11.1",
        "@electron-forge/maker-rpm": "7.11.1",
        "@electron-forge/maker-squirrel": "7.11.1",
        "@electron-forge/maker-zip": "7.11.1",
        "@electron-forge/plugin-auto-unpack-natives": "7.11.1",
        "@electron-forge/plugin-fuses": "7.11.1",
        "@electron-forge/plugin-vite": "7.11.1",
        "@reforged/maker-appimage": "^5.2.0",
        "@tanstack/router-plugin": "1.167.22",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "drizzle-kit": "^0.31.10",
        "electron": "41.2.1",
        "jsdom": "^29.0.2",
        "vite": "8.0.8",
        "vitest": "^4.1.4"
    },
    "productName": "Day Flow"
}
