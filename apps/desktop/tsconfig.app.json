{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "strict": true,
        "noEmit": true,
        "target": "ES2023",
        "lib": ["ES2023", "DOM", "DOM.Iterable"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "types": ["vite/client"],
        "isolatedModules": true,
        "moduleDetection": "force",
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@day-flow/auth-server/*": ["../auth-server/src/*"],
            "@day-flow/contracts/*": ["../../packages/contracts/src/*"],
            "@day-flow/db/*": ["../../packages/db/src/*"],
            "@day-flow/integrations-google/*": ["../../packages/integrations-google/src/*"]
        },
        "tsBuildInfoFile": "../../node_modules/.cache/apps-desktop-tsconfig.app.tsbuildinfo"
    },
    "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"]
}
