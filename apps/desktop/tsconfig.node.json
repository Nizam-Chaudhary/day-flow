{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "strict": true,
        "noEmit": true,
        "target": "ES2023",
        "lib": ["ES2023"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "types": ["node"],
        "isolatedModules": true,
        "moduleDetection": "force",
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./src/*"],
            "@day-flow/auth-server/*": ["../auth-server/src/*"],
            "@day-flow/contracts/*": ["../../packages/contracts/src/*"],
            "@day-flow/db/*": ["../../packages/db/src/*"],
            "@day-flow/integrations-google/*": ["../../packages/integrations-google/src/*"]
        },
        "tsBuildInfoFile": "../../node_modules/.cache/apps-desktop-tsconfig.node.tsbuildinfo"
    },
    "include": [
        "forge.config.ts",
        "vitest.config.ts",
        "vite.*.config.ts",
        "src/main.ts",
        "src/main/**/*.ts",
        "src/packaging/**/*.ts",
        "src/preload.ts",
        "src/preload/**/*.ts",
        "src/shared/**/*.ts",
        "src/**/*.d.ts",
        "vite.config.ts"
    ]
}
