{
    "name": "@day-flow/auth-server",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./google-auth-server": {
            "types": "./dist/google-auth-server.d.ts",
            "default": "./dist/google-auth-server.js"
        }
    },
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --resolve-full-paths",
        "clean": "rimraf dist",
        "format": "oxfmt .",
        "lint": "oxlint . --fix --fix-suggestions",
        "test": "vitest run --passWithNoTests"
    },
    "dependencies": {
        "@day-flow/env": "*",
        "@hono/node-server": "^1.14.1",
        "hono": "^4.8.3"
    },
    "devDependencies": {
        "@types/node": "25.6.0",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "6.0.3",
        "vitest": "^4.1.4"
    }
}
