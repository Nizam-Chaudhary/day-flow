{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "composite": false,
        "noEmit": false,
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "declarationMap": false,
        "sourceMap": true,
        "module": "ESNext"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/*.test.ts"]
}
