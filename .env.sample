# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Local auth server
DAY_FLOW_AUTH_HOST=127.0.0.1
DAY_FLOW_AUTH_PORT=8787

# Development flags
DAY_FLOW_OPEN_DEVTOOLS=false

# Linux platform tuning
DAY_FLOW_OZONE_PLATFORM=
DAY_FLOW_WAYLAND_COLOR_MANAGER=false
